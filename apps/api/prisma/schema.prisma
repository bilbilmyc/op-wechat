// Prisma schema for op-wechat.
//
// 11 tables per spec §5. All primary keys are UUID. All tenant-scoped tables
// have a wechat_app_id FK from day 1 (multi-app isolation).
//
// Naming: snake_case in DB, camelCase in Prisma client. Map with @@map + @map.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- A. Configuration / Identity ---

model Admin {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  role         String   @default("admin")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  sentMessages        Message[]      @relation("SentByAdmin")
  assignedConversations Conversation[] @relation("AssignedTo")
  createdBroadcasts   Broadcast[]

  @@map("admins")
}

model WechatApp {
  id             String   @id @default(uuid()) @db.Uuid
  name           String
  appId          String   @unique @map("app_id")
  appSecretEnc   String   @map("app_secret_enc")
  token          String
  encodingAesKey String   @map("encoding_aes_key")
  type           String // 'subscription' | 'service'
  avatarUrl      String?  @map("avatar_url")
  qrUrl          String?  @map("qr_url")
  // Token cache (persisted for cross-process sharing; refreshed by scheduler)
  accessToken    String?  @map("access_token")
  tokenExpiresAt DateTime? @map("token_expires_at")
  // Per-app settings
  broadcastRatePerMin Int @default(50) @map("broadcast_rate_per_min")
  disabled       Boolean  @default(false)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  fans          Fan[]
  fanTags       FanTag[]
  messages      Message[]
  conversations Conversation[]
  broadcasts    Broadcast[]
  rules         Rule[]

  @@map("wechat_apps")
}

// --- B. Fans ---

model Fan {
  id              String   @id @default(uuid()) @db.Uuid
  wechatAppId     String   @map("wechat_app_id") @db.Uuid
  openid          String
  unionid         String?
  nickname        String?
  avatarUrl       String?  @map("avatar_url")
  subscribeStatus String   @default("subscribed") @map("subscribe_status")
  subscribedAt    DateTime? @map("subscribed_at")
  unsubscribedAt  DateTime? @map("unsubscribed_at")
  remark          String?
  lastActiveAt    DateTime? @map("last_active_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  wechatApp      WechatApp          @relation(fields: [wechatAppId], references: [id], onDelete: Cascade)
  tagAssignments FanTagAssignment[]
  messages       Message[]
  conversation   Conversation?
  ruleExecutions RuleExecution[]

  @@unique([wechatAppId, openid])
  @@index([unionid])
  @@map("fans")
}

model FanTag {
  id          String @id @default(uuid()) @db.Uuid
  wechatAppId String @map("wechat_app_id") @db.Uuid
  wechatTagId Int    @map("wechat_tag_id")
  name        String
  createdAt   DateTime @default(now()) @map("created_at")

  wechatApp   WechatApp          @relation(fields: [wechatAppId], references: [id], onDelete: Cascade)
  assignments FanTagAssignment[]

  @@unique([wechatAppId, wechatTagId])
  @@map("fan_tags")
}

model FanTagAssignment {
  fanId      String   @map("fan_id") @db.Uuid
  tagId      String   @map("tag_id") @db.Uuid
  assignedAt DateTime @default(now()) @map("assigned_at")

  fan Fan    @relation(fields: [fanId], references: [id], onDelete: Cascade)
  tag FanTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([fanId, tagId])
  @@map("fan_tag_assignments")
}

// --- C. Messages and conversations ---

model Message {
  id          String   @id @default(uuid()) @db.Uuid
  wechatAppId String   @map("wechat_app_id") @db.Uuid
  fanId       String   @map("fan_id") @db.Uuid
  direction   String // 'inbound' | 'outbound'
  msgType     String   @map("msg_type")
  content     String   @db.Text
  mediaId     String?  @map("media_id")
  wechatMsgId String?  @map("wechat_msg_id")
  status      String   @default("received")
  agentId     String?  @map("agent_id") @db.Uuid
  errorMsg    String?  @map("error_msg")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  wechatApp WechatApp @relation(fields: [wechatAppId], references: [id], onDelete: Cascade)
  fan       Fan       @relation(fields: [fanId], references: [id], onDelete: Cascade)
  agent     Admin?    @relation("SentByAdmin", fields: [agentId], references: [id])

  @@index([wechatAppId, fanId, createdAt(sort: Desc)])
  @@index([wechatAppId, createdAt(sort: Desc)])
  @@map("messages")
}

model Conversation {
  id                 String   @id @default(uuid()) @db.Uuid
  wechatAppId        String   @map("wechat_app_id") @db.Uuid
  fanId              String   @map("fan_id") @db.Uuid
  lastMessageAt      DateTime? @map("last_message_at")
  lastMessagePreview String?  @map("last_message_preview") @db.Text
  unreadCount        Int      @default(0) @map("unread_count")
  assignedAgentId    String?  @map("assigned_agent_id") @db.Uuid
  status             String   @default("open")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  wechatApp    WechatApp @relation(fields: [wechatAppId], references: [id], onDelete: Cascade)
  fan          Fan       @relation(fields: [fanId], references: [id], onDelete: Cascade)
  assignedAgent Admin?   @relation("AssignedTo", fields: [assignedAgentId], references: [id])

  @@unique([fanId])
  @@unique([wechatAppId, fanId])
  @@index([wechatAppId, lastMessageAt(sort: Desc)])
  @@map("conversations")
}

// --- D. Broadcasts ---

model Broadcast {
  id              String   @id @default(uuid()) @db.Uuid
  wechatAppId     String   @map("wechat_app_id") @db.Uuid
  createdById     String   @map("created_by") @db.Uuid
  contentType     String   @map("content_type")
  contentJson     Json     @map("content_json")
  targetType      String   @map("target_type")
  targetFilterJson Json?   @map("target_filter_json")
  status          String   @default("draft")
  scheduledAt     DateTime? @map("scheduled_at")
  sentAt          DateTime? @map("sent_at")
  totalCount      Int      @default(0) @map("total_count")
  successCount    Int      @default(0) @map("success_count")
  failedCount     Int      @default(0) @map("failed_count")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  wechatApp WechatApp        @relation(fields: [wechatAppId], references: [id], onDelete: Cascade)
  createdBy Admin            @relation(fields: [createdById], references: [id])
  targets   BroadcastTarget[]

  @@map("broadcasts")
}

model BroadcastTarget {
  id          String   @id @default(uuid()) @db.Uuid
  broadcastId String   @map("broadcast_id") @db.Uuid
  fanId       String   @map("fan_id") @db.Uuid
  status      String   @default("pending")
  sentAt      DateTime? @map("sent_at")
  errorMsg    String?  @map("error_msg")

  broadcast Broadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)

  @@index([broadcastId, status])
  @@map("broadcast_targets")
}

// --- E. Auto-reply rules ---

model Rule {
  id                String   @id @default(uuid()) @db.Uuid
  wechatAppId       String   @map("wechat_app_id") @db.Uuid
  name              String
  triggerType       String   @map("trigger_type")
  triggerConfigJson Json     @map("trigger_config_json")
  actionType        String   @map("action_type")
  actionConfigJson  Json     @map("action_config_json")
  priority          Int      @default(0)
  stopPropagation   Boolean  @default(false) @map("stop_propagation")
  enabled           Boolean  @default(true)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  wechatApp  WechatApp      @relation(fields: [wechatAppId], references: [id], onDelete: Cascade)
  executions RuleExecution[]

  @@index([wechatAppId, enabled, priority(sort: Desc)])
  @@map("rules")
}

model RuleExecution {
  id          String   @id @default(uuid()) @db.Uuid
  ruleId      String   @map("rule_id") @db.Uuid
  fanId       String   @map("fan_id") @db.Uuid
  triggeredAt DateTime @default(now()) @map("triggered_at")
  messageId   String?  @map("message_id") @db.Uuid
  actionTaken String?  @map("action_taken")
  success     Boolean  @default(false)
  errorMsg    String?  @map("error_msg")

  rule Rule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  fan  Fan  @relation(fields: [fanId], references: [id], onDelete: Cascade)

  @@index([ruleId, triggeredAt(sort: Desc)])
  @@map("rule_executions")
}
