{
  "name": "op-wechat",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run dev -w apps/api",
    "dev:webhook": "npm run dev -w apps/webhook",
    "dev:scheduler": "npm run dev -w apps/scheduler",
    "dev:web": "npm run dev -w apps/web",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p apps/api && tsc --noEmit -p apps/webhook && tsc --noEmit -p apps/scheduler && tsc --noEmit -p packages/shared",
    "format": "prettier --write .",
    "db:migrate": "npm run db:migrate -w apps/api",
    "db:seed": "npm run db:seed -w apps/api",
    "db:studio": "npm run db:studio -w apps/api",
    "db:reset": "npm run db:reset -w apps/api"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0",
    "eslint": "^8.57.0",
    "prettier": "^3.3.0",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20"
  }
}
