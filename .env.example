# --- Database ---
POSTGRES_USER=opwechat
POSTGRES_PASSWORD=opwechat_dev_password
POSTGRES_DB=opwechat
DATABASE_URL=postgresql://opwechat:opwechat_dev_password@localhost:5432/opwechat

# --- Session ---
# 32+ bytes; rotate in production
SESSION_SECRET=change-me-to-a-32-byte-random-string-aaaaaaaaaaaa

# --- App secret encryption ---
# 32 bytes hex (64 hex chars). Used to encrypt wechat_apps.app_secret and
# encoding_aes_key at rest. Rotate carefully — rotation requires re-encrypting
# all existing rows.
APP_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# --- WeChat API ---
WECHAT_API_BASE=https://api.weixin.qq.com

# --- Service ports (local dev only) ---
API_PORT=3001
WEBHOOK_PORT=3002
SCHEDULER_PORT=3003
WEB_PORT=5173

# --- Public origin (for callback URLs in WeChat admin) ---
PUBLIC_ORIGIN=http://localhost
